# =============================================================================
# .env.example — Environment variable template
# OT/ICS HMI Web Application — Legacy Build for Moxa UC-8220 / Debian 9
#
# Copy this file to .env and fill in values for your lab environment:
#   cp .env.example .env
#   nano .env
# =============================================================================

# --- Flask ---
SECRET_KEY=change-me-in-production
DEBUG=true

# --- Web server binding ---
# Bind to 0.0.0.0 to accept connections on all interfaces (IT + OT)
# Restrict to eth0 IP (e.g. 192.168.1.50) for IT-only exposure
WEB_HOST=0.0.0.0
WEB_PORT=5000

# --- PLC Connection (OT-side, eth1 network) ---
PLC_IP=192.168.0.10
PLC_SLOT=0
PLC_TIMEOUT=3.0
POLL_INTERVAL=2.0

# --- Simulated PLC (set to true if no physical PLC is available) ---
# When true, the app generates realistic oscillating fake tag values
# without requiring an EtherNet/IP connection
USE_SIMULATED_PLC=false

# --- Tag name overrides (optional) ---
# Override the Logix tag names if your PLC uses different names.
# Leave blank to use defaults.
TAG_TANK_LEVEL=Tank_Level
TAG_PUMP_SPEED=Pump_Speed
TAG_PRESSURE=Pressure
TAG_TEMPERATURE=Temperature
TAG_FLOW_RATE=Flow_Rate
TAG_MOTOR_RPM=Motor_RPM
